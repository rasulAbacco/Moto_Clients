//app
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String  @id @default(uuid())
  name  String
  phone String  @unique
  email String?
  dob   String?

  profileImage     Bytes? // ✅ store binary
  profileImageType String? // ✅ image/jpeg, image/png

  role     Role    @default(USER)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address  UserAddress?
  vehicles Vehicle[]
  bookings Booking[]
}

model UserAddress {
  id         String  @id @default(uuid())
  userId     String  @unique
  street     String?
  city       String?
  state      String?
  postalCode String?
  country    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VehicleType {
  id   String @id @default(uuid())
  name String @unique

  brands   Brand[]
  vehicles Vehicle[]
  services Service[]
}

model Brand {
  id            String @id @default(uuid())
  name          String @unique
  vehicleTypeId String

  vehicleType VehicleType @relation(fields: [vehicleTypeId], references: [id])

  models  Model[]
  Vehicle Vehicle[]
}

model Model {
  id      String @id @default(uuid())
  name    String
  brandId String

  brand Brand @relation(fields: [brandId], references: [id])

  vehicles Vehicle[]

  // ADD THIS
  segment   VehicleSegment
  ModelYear ModelYear[]
}

model Vehicle {
  id            String  @id @default(uuid())
  userId        String
  vehicleTypeId String
  brandId       String
  modelId       String
  modelYearId   String?
  registration  String?
  fuelType      String?
  isPrimary     Boolean @default(false) // ✅ ADD THIS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  vehicleType VehicleType @relation(fields: [vehicleTypeId], references: [id])
  brand       Brand       @relation(fields: [brandId], references: [id])
  model       Model       @relation(fields: [modelId], references: [id])
  modelYear   ModelYear?  @relation(fields: [modelYearId], references: [id])

  bookings Booking[]

  @@index([userId])
}

model Garage {
  id        String @id @default(uuid())
  name      String
  address   String
  city      String
  latitude  Float
  longitude Float

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  services GarageService[]
  bookings Booking[]
}

model MainService {
  id   String @id @default(uuid())
  name String
  slug String @unique

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections ServiceSection[]
}

model ServiceSection {
  id            String @id @default(uuid())
  name          String
  mainServiceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mainService MainService @relation(fields: [mainServiceId], references: [id])

  services Service[]
}

model Service {
  id   String @id @default(uuid())
  name String

  vehicleTypeId String
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])

  sectionId String
  section   ServiceSection @relation(fields: [sectionId], references: [id])

  description String?

  // platform default pricing
  price         Float
  originalPrice Float?

  discountType  DiscountType?
  discountValue Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garages  GarageService[]
  bookings Booking[]

  @@index([vehicleTypeId])
}

model GarageService {
  id        String @id @default(uuid())
  garageId  String
  serviceId String

  price Float? // vendor override price

  garage  Garage  @relation(fields: [garageId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([garageId, serviceId])
  @@index([serviceId])
}

model Booking {
  id String @id @default(uuid())

  userId    String
  garageId  String
  serviceId String
  vehicleId String

  status BookingStatus @default(PENDING)

  scheduledAt DateTime
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  garage  Garage  @relation(fields: [garageId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  payments Payment[]

  @@index([userId])
}

model Payment {
  id        String @id @default(uuid())
  bookingId String
  amount    Float

  status PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

model ModelYear {
  id           String  @id @default(uuid())
  modelId      String
  year         Int
  heroUrl      String?
  thumbnailUrl String?

  model Model @relation(fields: [modelId], references: [id])

  vehicles Vehicle[]

  @@unique([modelId, year])
}

// --- CRM LOCAL SCHEMA UPDATES ---

model MarketplaceService {
  id                Int     @id @default(autoincrement())
  externalServiceId String  @unique // 🔑 Stores the UUID from the App DB
  name              String
  description       String?
  image             String?

  // Relations
  garageServices GarageMarketplaceService[]
  packageItems   MarketplacePackageItem[]
  bookings       MarketplaceBooking[]
}

model GarageMarketplaceService {
  id        Int     @id @default(autoincrement())
  userId    Int // The ID of the Garage User in your CRM
  serviceId Int // References MarketplaceService.id (Internal)
  isActive  Boolean @default(false)
  duration  Int? // Optional: specific time for this garage

  // Relations
  service MarketplaceService     @relation(fields: [serviceId], references: [id])
  pricing GarageServicePricing[]

  @@unique([userId, serviceId])
}

model GarageServicePricing {
  id              Int    @id @default(autoincrement())
  garageServiceId Int
  carType         String // 🔑 Matches VehicleSegment (SEDAN, SUV, etc.)
  price           Float
  discount        Float  @default(0)

  // Relations
  garageMarketplaceService GarageMarketplaceService @relation(fields: [garageServiceId], references: [id], onDelete: Cascade)
}

// Update your existing MarketplaceBooking model to include these snapshots
model MarketplaceBooking {
  id        Int @id @default(autoincrement())
  serviceId Int
  garageId  Int
  clientId  Int

  status      BookingStatus @default(PENDING)
  scheduledAt DateTime

  // Pricing Snapshots (Storage of what was paid)
  carType    String?
  finalPrice Float

  service MarketplaceService @relation(fields: [serviceId], references: [id])
}

model MarketplacePackage {
  id        Int      @id @default(autoincrement())
  userId    Int // The Garage User ID
  name      String
  price     Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items MarketplacePackageItem[]
}

model MarketplacePackageItem {
  id          Int    @id @default(autoincrement())
  packageId   Int
  serviceId   Int // References MarketplaceService.id
  serviceName String // Snapshot of name
  basePrice   Float  @default(0)

  package            MarketplacePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  marketplaceService MarketplaceService @relation(fields: [serviceId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum VehicleSegment {
  HATCHBACK
  SEDAN
  SUV
  LUXURY
  SUPER_LUXURY
  PICKUP
  VAN
}
