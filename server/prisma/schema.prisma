generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id                 String   @id @default(uuid())
  name               String
  phone              String   @unique
  email              String?
  dob                String? // Date of Birth (stored as string e.g. "1990-05-21")
  company            String? // Company / Organisation
  taxNumber          String? // Tax / VAT Number
  registrationNumber String? // Registration Number
  role               Role     @default(USER)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  address  UserAddress?
  bookings Booking[]
  vehicles Vehicle[]
}

//////////////////////////////////////////////////////
// USER ADDRESS (one-to-one)
//////////////////////////////////////////////////////

model UserAddress {
  id         String  @id @default(uuid())
  userId     String  @unique
  street     String?
  city       String?
  state      String?
  postalCode String?
  country    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// GARAGE
//////////////////////////////////////////////////////

model Garage {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  bookings Booking[]
}

//////////////////////////////////////////////////////
// MAIN SERVICE (12 top-level categories)
//////////////////////////////////////////////////////

model MainService {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections ServiceSection[]
}

//////////////////////////////////////////////////////
// SERVICE SECTION (like Brake Maintenance, SPA, etc.)
//////////////////////////////////////////////////////

model ServiceSection {
  id            String   @id @default(uuid())
  name          String
  mainServiceId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mainService MainService @relation(fields: [mainServiceId], references: [id])
  services    Service[]
}

//////////////////////////////////////////////////////
// SUB SERVICE (Actual Bookable Item)
//////////////////////////////////////////////////////

model Service {
  id   String @id @default(uuid())
  name String

  // Base pricing
  price         Float
  originalPrice Float?

  // Discount system
  discountType  DiscountType?
  discountValue Float?

  isActive Boolean @default(true)

  sectionId String
  section   ServiceSection @relation(fields: [sectionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

//////////////////////////////////////////////////////
// BOOKING
//////////////////////////////////////////////////////

model Booking {
  id          String        @id @default(uuid())
  userId      String
  garageId    String
  serviceId   String
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  createdAt   DateTime      @default(now())

  user    User    @relation(fields: [userId], references: [id])
  garage  Garage  @relation(fields: [garageId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  payments Payment[]
}

//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

model Payment {
  id        String        @id @default(uuid())
  bookingId String
  amount    Float
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

//////////////////////////////////////////////////////
// VEHICLE
//////////////////////////////////////////////////////

model Vehicle {
  id           String   @id @default(uuid())
  userId       String
  registration String   @unique
  company      String
  model        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}
